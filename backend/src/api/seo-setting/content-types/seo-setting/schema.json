{
  "kind": "singleType",
  "collectionName": "seo_settings",
  "info": {
    "singularName": "seo-setting",
    "pluralName": "seo-settings",
    "displayName": "SEO сайта",
    "description": "Метаданные поисковой оптимизации, социальных сетей и организации"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "metaTitle": {
      "type": "string",
      "required": true,
      "maxLength": 70
    },
    "metaDescription": {
      "type": "text",
      "required": true,
      "maxLength": 180
    },
    "keywords": {
      "type": "text"
    },
    "canonicalUrl": {
      "type": "string"
    },
    "robots": {
      "type": "string",
      "required": true,
      "default": "index, follow"
    },
    "socialTitle": {
      "type": "string",
      "required": true,
      "maxLength": 70
    },
    "socialDescription": {
      "type": "text",
      "required": true,
      "maxLength": 200
    },
    "socialImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "organizationName": {
      "type": "string",
      "required": true
    },
    "legalName": {
      "type": "string",
      "required": true
    },
    "organizationDescription": {
      "type": "text",
      "required": true
    },
    "organizationAddress": {
      "type": "text",
      "required": true
    }
  }
}
