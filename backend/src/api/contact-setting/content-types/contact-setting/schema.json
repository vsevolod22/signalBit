{
  "kind": "singleType",
  "collectionName": "contact_settings",
  "info": {
    "singularName": "contact-setting",
    "pluralName": "contact-settings",
    "displayName": "Настройки контактов",
    "description": "Медиа и партнёры блока контактов"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "questionTitle": {
      "type": "string",
      "required": true
    },
    "emailLabel": {
      "type": "string",
      "required": true
    },
    "emailAddress": {
      "type": "email",
      "required": true
    },
    "responseText": {
      "type": "text",
      "required": true
    },
    "formEyebrow": {
      "type": "string",
      "required": true
    },
    "formTitle": {
      "type": "string",
      "required": true
    },
    "formDescription": {
      "type": "text",
      "required": true
    },
    "partnersTitle": {
      "type": "string",
      "required": true
    },
    "emailIcon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "rightImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "partnerLogos": {
      "type": "component",
      "repeatable": true,
      "component": "common.partner-logo"
    }
  }
}
