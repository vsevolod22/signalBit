VITE_STRAPI_API_URL=http://localhost:1337
# Required in production for canonical, Open Graph URLs and sitemap generation.
VITE_SITE_URL=https://your-production-domain.example
# Optional endpoint for the contact form. Without it the UI clearly uses demo mode.
VITE_CONTACT_FORM_ENDPOINT=

# Optional: only needed if you run docker compose directly from the repository root.
DATABASE_NAME=signalbit_cms
DATABASE_USERNAME=signalbit
DATABASE_PASSWORD=signalbit_password
