{
  "name": "signal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@react-spring/web": "^10.1.2",
    "@tanstack/react-query": "^5.100.9",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.40.0",
    "react": "^18.2.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.81.0",
    "sass": "^1.77.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite --config frontend/vite.config.ts --host 127.0.0.1 --port 5174",
    "start": "vite",
    "build": "tsc --noEmit && vite build",
    "build:frontend": "tsc -p frontend/tsconfig.json --noEmit && vite build --config frontend/vite.config.ts && vite build --config frontend/vite.config.ts --ssr src/entry-server.tsx --outDir ../dist-frontend-ssr && node scripts/prerender-frontend.mjs",
    "check": "pnpm check:code && pnpm check:styles",
    "check:code": "biome check frontend/src frontend/*.ts",
    "check:styles": "prettier --check \"frontend/src/**/*.scss\" && stylelint \"frontend/src/**/*.scss\"",
    "preview:frontend": "vite preview --config frontend/vite.config.ts --host 127.0.0.1 --port 4174",
    "preview": "vite preview",
    "format": "pnpm format:code && pnpm format:styles",
    "format:code": "biome check --write frontend/src frontend/*.ts",
    "format:styles": "stylelint \"frontend/src/**/*.scss\" --fix && prettier --write \"frontend/src/**/*.scss\"",
    "test": "vitest run && vitest run --config frontend/vitest.config.ts",
    "test:watch": "vitest",
    "db:up": "docker compose --env-file backend/.env up -d postgres",
    "db:down": "docker compose --env-file backend/.env down",
    "db:reset": "docker compose --env-file backend/.env down -v && docker compose --env-file backend/.env up -d postgres",
    "backend:dev": "pnpm --dir backend develop",
    "backend:build": "pnpm --dir backend build",
    "backend:start": "pnpm --dir backend start",
    "backend:import-media": "pnpm --dir backend import:frontend-media",
    "deploy:cms": "bash scripts/deploy-cms.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.17",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
