{
  "name": "signal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "dependencies": {
    "@tanstack/react-query": "^5.100.9",
    "date-fns": "^4.1.0",
    "react": "^18.2.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.2.0",
    "sass": "^1.77.5",
    "zod": "^4.4.3"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose --env-file backend/.env up -d postgres",
    "db:down": "docker compose --env-file backend/.env down",
    "db:reset": "docker compose --env-file backend/.env down -v && docker compose --env-file backend/.env up -d postgres",
    "backend:dev": "pnpm --dir backend develop",
    "backend:build": "pnpm --dir backend build",
    "backend:start": "pnpm --dir backend start",
    "backend:import-media": "pnpm --dir backend import:frontend-media",
    "deploy:cms": "bash scripts/deploy-cms.sh"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
